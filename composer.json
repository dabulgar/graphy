{
    "name": "davos/graphy",
    "description": "A PHP abstraction layer for creating, updating, and fetching RRDTool databases with fluent model-based APIs.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/dabulgar/graphy",
    "support": {
        "issues": "https://github.com/dabulgar/graphy/issues",
        "source": "https://github.com/dabulgar/graphy"
    },
    "keywords": [
        "rrd",
        "rrdtool",
        "graph",
        "metrics",
        "timeseries",
        "monitoring"
    ],
    "authors": [
        {
            "name": "David Ivanov",
            "email": "ivanovdavid441@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-rrd": "*",
        "ext-mbstring": "*",
        "ext-ctype": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "Davos\\Graphy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Davos\\Graphy\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs:check": "php-cs-fixer check --diff",
        "cs:fix": "php-cs-fixer fix --diff",
        "quality": [
            "@cs:check",
            "@stan",
            "@test"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
